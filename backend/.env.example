# MongoDB Atlas Connection String
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/hospital_triage?retryWrites=true&w=majority

# AI Service URL — use your ngrok URL when deployed on Render
AI_URL=https://abc123.ngrok-free.app

# Port (Render auto-assigns, keep 5000 for local)
PORT=5000

# Frontend URL for CORS (Vercel URL)
FRONTEND_URL=https://your-app.vercel.app
